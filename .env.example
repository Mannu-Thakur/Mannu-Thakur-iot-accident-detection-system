# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/perseva

# Redis Configuration (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Device API Key Salt
DEVICE_API_KEY_SALT=your-device-api-key-salt

# Live Access Configuration
LIVE_ACCESS_WINDOW_SECONDS=60
STREAM_TOKEN_EXPIRES_SECONDS=300

# AI Configuration (placeholder for production)
AI_SERVICE_URL=http://localhost:5000/analyze
AI_ENABLED=false

# SMS Configuration (Twilio - add keys in production)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email Configuration (optional)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Heartbeat Configuration
HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_STALE_THRESHOLD_MULTIPLIER=3

# Severity Auto-Dispatch Threshold (1-5)
AUTO_DISPATCH_SEVERITY_THRESHOLD=4

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
